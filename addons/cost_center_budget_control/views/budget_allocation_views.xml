<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Budget Allocation Form View -->
    <record id="view_budget_allocation_form" model="ir.ui.view">
        <field name="name">budget.allocation.form</field>
        <field name="model">budget.allocation</field>
        <field name="arch" type="xml">
            <form string="Budget Allocation">
                <header>
                    <button name="action_allocate" string="Allocate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Q1 Overhead Allocation"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="source_cost_center_id" readonly="state != 'draft'"/>
                            <field name="amount_base" readonly="state != 'draft'"/>
                            <field name="allocation_date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="overhead_account_id" readonly="state != 'draft'"/>
                            <field name="target_account_id" readonly="state != 'draft'"/>
                            <field name="journal_id" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allocation Lines" name="rules">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="cost_center_id"
                                           domain="[('company_id', '=', parent.company_id)]"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="percentage" sum="Total Percentage" widget="integer"/>
                                </list>
                            </field>
                        </page>
                        <page string="Journal Postings" name="postings" invisible="state == 'draft'">
                            <group>
                                <field name="move_id" readonly="1"/>
                                <field name="reversal_move_id" readonly="1" invisible="not reversal_move_id"/>
                            </group>
                        </page>
                    </notebook>
                    <group string="Recurring" name="recurring" invisible="not is_recurring" col="4">
                        <field name="is_recurring"/>
                        <field name="recurring_interval_months" required="is_recurring"/>
                        <field name="last_run_date" readonly="1"/>
                        <field name="recurring_count" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Budget Allocation List View -->
    <record id="view_budget_allocation_list" model="ir.ui.view">
        <field name="name">budget.allocation.list</field>
        <field name="model">budget.allocation</field>
        <field name="arch" type="xml">
            <list string="Budget Allocations" decoration-success="state == 'posted'" decoration-muted="state == 'cancelled'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="source_cost_center_id"/>
                <field name="currency_id" invisible="1"/>
                <field name="amount_base" sum="Total Amount"/>
                <field name="allocation_date"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Budget Allocation Action -->
    <record id="action_budget_allocation" model="ir.actions.act_window">
        <field name="name">Budget Allocations</field>
        <field name="res_model">budget.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first overhead budget allocation.
            </p>
        </field>
    </record>

</odoo>
