<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_budget_allocation_reporting_pivot" model="ir.ui.view">
        <field name="name">budget.allocation.reporting.pivot</field>
        <field name="model">budget.allocation</field>
        <field name="arch" type="xml">
            <pivot string="Allocation Analysis" disable_linking="1">
                <field name="amount_base" type="measure" string="Base Amount"/>

                <field name="allocation_date" type="row" interval="month"/>
                <field name="source_cost_center_id" type="row"/>
                <field name="company_id" type="col"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_budget_allocation_reporting_graph" model="ir.ui.view">
        <field name="name">budget.allocation.reporting.graph</field>
        <field name="model">budget.allocation</field>
        <field name="arch" type="xml">
            <graph string="Allocation Graphs" type="bar" disable_linking="1">
                <field name="amount_base" type="measure" string="Base Amount"/>
                <field name="allocation_date" type="row" interval="month"/>
                <field name="source_cost_center_id" type="col"/>
            </graph>
        </field>
    </record>

    <record id="action_allocation_analysis" model="ir.actions.act_window">
        <field name="name">Allocation Analysis</field>
        <field name="res_model">budget.allocation</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="view_id" ref="view_budget_allocation_reporting_pivot"/>
        <field name="context">{'search_default_posted': 1}</field>
    </record>

</odoo>
