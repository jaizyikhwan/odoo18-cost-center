<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.cost_center_budget_control</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Budget Control" id="budget_control_settings">
                    <setting string="Enable Budget Control" help="Activate or deactivate all budget control functionalities.">
                        <field name="budget_control_enabled"/>
                    </setting>
                    <setting string="Control Mode" help="Choose how the system reacts when budgets exceed their thresholds." invisible="not budget_control_enabled">
                        <div class="content-group">
                            <div class="row">
                                <label for="budget_control_mode" class="col-lg-3 o_light_label"/>
                                <field name="budget_control_mode"/>
                            </div>
                        </div>
                    </setting>
                </block>
                <block title="Budget Thresholds" id="budget_thresholds_settings" invisible="not budget_control_enabled">
                    <setting string="Warning Threshold (%)" help="The percentage of budget usage that triggers a warning message.">
                        <div class="content-group">
                            <div class="row">
                                <label for="budget_warning_threshold" class="col-lg-3 o_light_label"/>
                                <field name="budget_warning_threshold"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Critical Threshold (%)" help="The percentage of budget usage that triggers a critical alert.">
                        <div class="content-group">
                            <div class="row">
                                <label for="budget_critical_threshold" class="col-lg-3 o_light_label"/>
                                <field name="budget_critical_threshold"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Blocking Threshold (%)" help="The percentage of budget usage that blocks posting of an account move in 'Blocking' mode.">
                        <div class="content-group">
                            <div class="row">
                                <label for="budget_blocking_threshold" class="col-lg-3 o_light_label"/>
                                <field name="budget_blocking_threshold"/>
                            </div>
                        </div>
                    </setting>
                </block>
                <block title="Budget Notifications" id="budget_notification_settings" invisible="not budget_control_enabled">
                    <setting string="Chatter Alerts" help="Display budget alerts in the chatter of related documents.">
                        <field name="budget_chatter_enabled"/>
                    </setting>
                    <setting string="Activity Scheduling" help="Schedule activities for budget managers when critical thresholds are exceeded.">
                        <field name="budget_activity_enabled"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
