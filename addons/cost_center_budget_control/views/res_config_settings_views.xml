<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.cost_center_budget_control</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']/div[@name='account_setting_container']" position="after">
                <h2>Budget Control</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Budget Control Activation</span>
                            <div class="text-muted">
                                Enable budget thresholds and control mechanisms.
                            </div>
                            <div class="content-group mt16">
                                <div class="row mt16">
                                    <label for="budget_control_enabled" class="o_light_label col-lg-4"/>
                                    <field name="budget_control_enabled"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="budget_control_mode_setting" attrs="{'invisible': [('budget_control_enabled', '=', False)]}">
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Control Mode</span>
                            <div class="text-muted">
                                Define how the system reacts to budget overruns.
                            </div>
                            <div class="content-group mt16">
                                <div class="row mt16">
                                    <label for="budget_control_mode" class="o_light_label col-lg-4"/>
                                    <field name="budget_control_mode"/>
                                </div>
                            </div>
                        </div>
                    </div>
                     <div class="col-12 col-lg-6 o_setting_box" id="budget_thresholds_settings" attrs="{'invisible': [('budget_control_enabled', '=', False)]}">
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Thresholds (%)</span>
                            <div class="text-muted">
                                Configure budget usage percentages for warnings, critical alerts, and blocking.
                            </div>
                            <div class="content-group mt16">
                                <div class="row mt16">
                                    <label for="budget_warning_threshold" class="o_light_label col-lg-4"/>
                                    <field name="budget_warning_threshold"/>
                                </div>
                                <div class="row mt16">
                                    <label for="budget_critical_threshold" class="o_light_label col-lg-4"/>
                                    <field name="budget_critical_threshold"/>
                                </div>
                                <div class="row mt16">
                                    <label for="budget_blocking_threshold" class="o_light_label col-lg-4"/>
                                    <field name="budget_blocking_threshold"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="budget_notification_settings" attrs="{'invisible': [('budget_control_enabled', '=', False)]}">
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Notification Settings</span>
                            <div class="text-muted">
                                Configure how budget alerts are communicated.
                            </div>
                            <div class="content-group mt16">
                                <div class="row mt16">
                                    <label for="budget_chatter_enabled" class="o_light_label col-lg-4"/>
                                    <field name="budget_chatter_enabled"/>
                                </div>
                                <div class="row mt16">
                                    <label for="budget_activity_enabled" class="o_light_label col-lg-4"/>
                                    <field name="budget_activity_enabled"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>