<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Daily check for due recurring allocations -->
    <record id="ir_cron_create_recurring_allocations" model="ir.cron">
        <field name="name">Budget: Create Recurring Allocations</field>
        <field name="model_id" ref="model_budget_allocation"/>
        <field name="state">code</field>
        <field name="code">model._cron_create_recurring_allocations()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="priority">20</field>
    </record>

</odoo>
