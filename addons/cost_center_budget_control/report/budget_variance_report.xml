<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="budget_variance_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="plan">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2 class="text-center">
                            Budget Variance Report
                        </h2>
                        <h4 class="text-center">
                            <t t-esc="plan.name"/>
                        </h4>

                        <div t-if="plan.revision_number > 1" class="alert alert-warning mt-3" style="border-left: 4px solid #fd7e14; background-color: #fff3cd; padding: 8px 12px;">
                            <strong>Revision <t t-esc="plan.revision_number"/></strong>
                            &#8212; this budget is a revision of
                            <strong><t t-esc="plan.parent_revision_id.name"/></strong>.
                            The original is preserved as immutable history.
                        </div>

                        <table class="table table-sm table-borderless mt-4" style="width:100%;">
                            <tr>
                                <td style="width:20%;"><strong>Cost Center:</strong></td>
                                <td>
                                    <t t-esc="plan.cost_center_id.code"/>
                                    —
                                    <t t-esc="plan.cost_center_id.name"/>
                                </td>
                                <td style="width:20%;"><strong>Status:</strong></td>
                                <td>
                                    <t t-esc="plan.state.title()"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Period:</strong></td>
                                <td>
                                    <t t-esc="plan.date_from"/>
                                    to
                                    <t t-esc="plan.date_to"/>
                                </td>
                                <td><strong>Currency:</strong></td>
                                <td>
                                    <t t-esc="plan.currency_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Company:</strong></td>
                                <td>
                                    <t t-esc="plan.company_id.name"/>
                                </td>
                                <td><strong>Active:</strong></td>
                                <td>
                                    <t t-if="plan.is_currently_active">Yes</t>
                                    <t t-else="">No</t>
                                </td>
                            </tr>
                        </table>

                        <t t-set="total_planned" t-value="0"/>
                        <t t-set="total_actual" t-value="0"/>
                        <t t-set="total_po_committed" t-value="0"/>
                        <t t-set="total_committed" t-value="0"/>
                        <t t-set="total_available" t-value="0"/>
                        <t t-set="total_remaining" t-value="0"/>
                        <t t-foreach="plan.line_ids" t-as="line">
                            <t t-set="total_planned" t-value="total_planned + line.planned_amount"/>
                            <t t-set="total_actual" t-value="total_actual + line.actual_amount"/>
                            <t t-set="total_po_committed" t-value="total_po_committed + line.po_committed_amount"/>
                            <t t-set="total_committed" t-value="total_committed + line.committed_amount"/>
                            <t t-set="total_available" t-value="total_available + line.available_amount"/>
                            <t t-set="total_remaining" t-value="total_remaining + line.remaining_amount"/>
                        </t>
                        <t t-set="overall_usage" t-value="(total_actual / total_planned * 100) if total_planned else 0"/>
                        <t t-set="overall_committed_pct" t-value="(total_committed / total_planned * 100) if total_planned else 0"/>

                        <h5 class="mt-4">Budget Lines</h5>
                        <table class="table table-sm table-bordered" style="width:100%;">
                            <thead>
                                <tr style="background-color:#714B67;color:white;">
                                    <th>Account</th>
                                    <th class="text-end">Planned</th>
                                    <th class="text-end">Actual</th>
                                    <th class="text-end">PO Committed</th>
                                    <th class="text-end">Committed</th>
                                    <th class="text-end">Available</th>
                                    <th class="text-end">Usage %</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="plan.line_ids" t-as="line">
                                    <tr>
                                        <td>
                                            <t t-esc="line.account_id.code"/>
                                            —
                                            <t t-esc="line.account_id.name"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'{:.2f}'.format(line.planned_amount)"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'{:.2f}'.format(line.actual_amount)"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'{:.2f}'.format(line.po_committed_amount)"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'{:.2f}'.format(line.committed_amount)"/>
                                        </td>
                                        <td class="text-end" t-att-style="('color:#dc3545;font-weight:bold;' if line.available_amount &lt; 0 else '')">
                                            <t t-esc="'{:.2f}'.format(line.available_amount)"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'{:.1f}'.format(line.usage_percent)"/>%
                                        </td>
                                        <td class="text-center">
                                            <span t-if="line.alert_level == 'exceeded'" style="background-color:#dc3545;color:white;padding:2px 6px;border-radius:3px;">
                                                Exceeded
                                            </span>
                                            <span t-if="line.alert_level == 'danger'" style="background-color:#fd7e14;color:white;padding:2px 6px;border-radius:3px;">
                                                Critical
                                            </span>
                                            <span t-if="line.alert_level == 'warning'" style="background-color:#ffc107;color:white;padding:2px 6px;border-radius:3px;">
                                                Warning
                                            </span>
                                            <span t-if="line.alert_level == 'normal'" style="background-color:#28a745;color:white;padding:2px 6px;border-radius:3px;">
                                                Normal
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color:#f0e6ee;font-weight:bold;">
                                    <td>TOTAL</td>
                                    <td class="text-end">
                                        <t t-esc="'{:.2f}'.format(total_planned)"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:.2f}'.format(total_actual)"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:.2f}'.format(total_po_committed)"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:.2f}'.format(total_committed)"/>
                                    </td>
                                    <td class="text-end" t-att-style="('color:#dc3545;' if total_available &lt; 0 else '')">
                                        <t t-esc="'{:.2f}'.format(total_available)"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:.1f}'.format(overall_usage)"/>%
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div t-if="plan.approved_by" class="mt-4 text-muted" style="font-size:11px;">
                            <strong>Approved by:</strong>
                            <t t-esc="plan.approved_by.name"/>
                            on
                            <t t-esc="plan.approved_date"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_budget_variance_report" model="ir.actions.report">
        <field name="name">Budget Variance Report</field>
        <field name="model">budget.plan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cost_center_budget_control.budget_variance_report</field>
        <field name="report_file">cost_center_budget_control.budget_variance_report</field>
        <field name="binding_model_id" ref="model_budget_plan"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
