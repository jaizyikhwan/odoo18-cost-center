<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_budget_approval_wizard_form" model="ir.ui.view">
        <field name="name">budget.approval.wizard.form</field>
        <field name="model">budget.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Budget Approval">
                <group>
                    <field name="plan_ids" readonly="1" widget="many2many_tags"/>
                    <field name="action_type" widget="radio"/>
                    <field name="comment" placeholder="Optional comment for the chatter..."/>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_budget_approval_wizard" model="ir.actions.act_window">
        <field name="name">Budget Approval</field>
        <field name="res_model">budget.approval.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_budget_plan"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
