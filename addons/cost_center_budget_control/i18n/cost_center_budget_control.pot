#. module: cost_center_budget_control
#: model:mail.template,body_html:cost_center_budget_control.mail_template_budget_over_budget
msgid ""
"<div style=\"font-family: Arial, sans-serif; padding: 20px; color: #333;\">\n"
"    <h2 style=\"color: #714B67;\">Budget Threshold Exceeded</h2>\n"
"\n"
"    <p>Hello,</p>\n"
"\n"
"    <p>\n"
"        The following budget line has exceeded its threshold and requires your attention:\n"
"    </p>\n"
"\n"
"    <table style=\"border-collapse: collapse; margin: 16px 0; width: 100%;\">\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Cost Center</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                {{ object.plan_id.cost_center_id.code }} — {{ object.plan_id.cost_center_id.name }}\n"
"            </td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Budget Plan</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">{{ object.plan_id.name }}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Account</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                {{ object.account_id.code }} — {{ object.account_id.name }}\n"
"            </td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Period</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                {{ object.plan_id.date_from }} to {{ object.plan_id.date_to }}\n"
"            </td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Planned Amount</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                {{ format_amount(object.planned_amount, object.currency_id) }}\n"
"            </td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Actual Amount</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                {{ format_amount(object.actual_amount, object.currency_id) }}\n"
"            </td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Usage</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd; color: #dc3545; font-weight: bold;\">\n"
"                {{ \"%.1f\"|format(object.usage_percent) }}%\n"
"            </td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Alert Level</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">\n"
"                <span style=\"background-color: #dc3545; color: white; padding: 2px 8px; border-radius: 3px;\">\n"
"                    {{ object.alert_level }}\n"
"                </span>\n"
"            </td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>\n"
"        Please review this budget and take appropriate action. You can:\n"
"    </p>\n"
"    <ul>\n"
"        <li>Adjust the planned amount if the budget was set too low</li>\n"
"        <li>Investigate the source of over-expenditure</li>\n"
"        <li>Cancel or close the budget if it's no longer relevant</li>\n"
"    </ul>\n"
"\n"
"    <p style=\"margin-top: 24px;\">\n"
"        <a href=\"%7B%7B%20object.get_base_url()%20%7D%7D/web#id=%7B%7B%20object.id%20%7D%7D&amp;view_type=form&amp;model=budget.plan.line\" style=\"background-color: #714B67; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;\">\n"
"            View Budget Line\n"
"        </a>\n"
"    </p>\n"
"\n"
"    <p style=\"color: #666; font-size: 12px; margin-top: 32px;\">\n"
"        This is an automated notification from the Cost Center &amp; Budget Control module.\n"
"    </p>\n"
"</div>\n"
"        "
msgstr ""

